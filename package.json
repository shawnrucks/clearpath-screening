{
  "name": "clearpath-screening",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 3010",
    "build": "next build --webpack",
    "start": "next start -p ${PORT:-3010}",
    "typecheck": "tsc --noEmit --pretty false",
    "test:api": "node tests/backend-e2e.mjs",
    "test:browser": "playwright test",
    "test:e2e": "npm run test:api && npm run test:browser",
    "check": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  }
}
